#!/bin/bash

interval=1

cpu() {
	cpu_val=$(grep -o "^[^ ]*" /proc/loadavg)
	printf " ’ŗø %s" "$cpu_val"
}

battery() {
	get_capacity=$(cat /sys/class/power_supply/BAT0/capacity)
	printf " ’ć” %s" "$get_capacity"
}

brightness() {
	brightness_val=$(cat /sys/class/backlight/*/brightness)
	printf " ’üé %s" "$brightness_val"
}

mem() {
	mem_val=$(free -h | awk '/^Mem/ { print $3 }' | sed 's/i//g')
	printf " Ņē” %s" "$mem_val"
}

wlan() {
	wifi_status=$(nmcli -t -f DEVICE,STATE dev | grep wlan | cut -d':' -f2)
	if [ "$wifi_status" == "connected" ]; then
		wifi_name=$(nmcli -t -f NAME connection show --active | tr '\n' ' ')
		printf " ’ć½  %s" "$wifi_name"
	else
		printf " ’ć½  Not connected"
	fi
}

volume() {
	vol=$(pactl list sinks | awk '/Volume:/ { if ($1 == "Volume:") { print $5; exit } }' | tr -d '%')
	mute=$(pactl list sinks | awk '/Mute:/ { if ($2 == "yes") { print "Muted"; exit } }')

	if [ -n "$mute" ]; then
		printf " ’Ć” Muted"
	else
		printf " ’Ć©  %s%%" "$vol"
	fi
}

clock() {
	printf " ’ĆŚ %s" "$(date '+%A, %B %d, %Y %H:%M:%S')"
}

update_status() {
	xsetroot -name "$(battery) $(brightness) $(cpu) $(mem) $(wlan) $(volume) $(clock)"
}

# Check if -d option is provided
if [[ "$*" == *-d* ]]; then
	while true; do
		update_status
		sleep "$interval"
	done
else
	update_status
fi
