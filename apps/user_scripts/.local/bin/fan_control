#!/bin/bash

FILE="/sys/devices/platform/asus-nb-wmi/hwmon/hwmon5/pwm1_enable"
FAN_HIGH=0
FAN_LOW=2

display_help() {
  echo "Usage: $0 [-h] [on|off|toggle]"
  echo "Control the fan speed of your computer."
  echo "Options:"
  echo "  -h, --help      Display this help message"
  echo "Commands:"
  echo "  on              Turn the fan on (high speed)"
  echo "  off             Turn the fan off"
  echo "  toggle          Toggle the fan speed between on and off"
}

set_fan_speed() {
  local new_value
  case "$1" in
    on) new_value=$FAN_HIGH ;;
    off) new_value=$FAN_LOW ;;
    toggle)
      current_value=$(<"$FILE")
      if [ "$current_value" -eq $FAN_HIGH ]; then
          new_value=$FAN_LOW
      else
          new_value=$FAN_HIGH
      fi
      ;;
    *)
      echo "Invalid command: $1"
      display_help
      exit 1
      ;;
  esac
  echo "$new_value" | tee "$FILE" >/dev/null
  echo "Fan speed set to: $(if [ "$new_value" -eq $FAN_HIGH ]; then echo "High"; else echo "Low"; fi)"
}

case "$1" in
  -h | --help)
    display_help
    exit 0
    ;;
  on | off | toggle)
    set_fan_speed "$1"
    ;;
  *)
    display_help
    exit 1
    ;;
esac
